---
import '../styles/global.css';
import { Font } from 'astro:assets';
const {title} = Astro.props
---

<html lang="en" >
	<head>
    <Font cssVariable="--font-jost" preload />
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<link rel="icon" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-secondary text-white max-w-[1440px] mx-auto px-6 flex flex-col gap-5 md:gap-0 overflow-x-hidden">
		<slot />
		<div class="relative left-[calc(50%-50vw)] w-screen py-8 border-t border-white/10 text-center text-[#C6C6CD] px-6">
      © 2026 HatchHouse LLP. Built on Integrity and Engineering Excellence.
    </div>
	</body>
</html>
