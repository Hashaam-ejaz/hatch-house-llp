---
interface Props {
  iconSrc: string;
  imageSrc: string;
  heading: string;
  subHeading: string;
}

const { iconSrc, heading, imageSrc, subHeading } = Astro.props;
---

<div
  class="flex flex-col h-[420px] md:h-[500px] w-full bg-secondary border border-gray-800 rounded-2xl overflow-hidden shadow-xl"
  id="services"
>
  <img
    src={imageSrc}
    alt={heading || "Service image"}
    class="w-full h-[244px] object-cover shrink-0"
  />

  <div class="flex flex-col justify-center flex-1 px-6 py-8">
    <div class="flex items-center gap-3 md:h-[50px]">
      <img src={iconSrc} alt="icon" class="w-[25px] h-[25px] shrink-0" />
      <h3 class="text-[24px] font-bold text-white tracking-tight leading-none">
        {heading}
      </h3>
    </div>

    <p class="text-[16px] font-normal text-[#C6C6CD] mt-4 leading-relaxed">
      {subHeading}
    </p>
  </div>
</div>
