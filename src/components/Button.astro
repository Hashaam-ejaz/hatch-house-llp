---
interface Props {
  text?: string;
  variant?: "primary" | "secondary" | "ghost" | "semiTransparent";
  class?: string;
  href?: string;
  target?: "_self" | "_blank";
  type?: "button" | "submit" | "reset";
}
const { text = "Click Here", variant = "primary", href, class: className, target = "_self", type = "button"} = Astro.props;

const Element = href ? 'a' : 'button';

const baseStyles = "px-[16px] md:px-4 py-2 md:py-2.5 transition-all duration-200 md:text-base text-xl rounded-full";

const variants = {
  primary: "text-white bg-primary font-medium",
  secondary: "text-secondary bg-white font-medium",
  ghost: "text-white bg-transparent font-medium",
  semiTransparent: "text-primary bg-primary/10 font-bold"
};


---

<Element href={href} class:list={[baseStyles, variants[variant], href ? "cursor-pointer" : "", className]} target={target}>
  {text}
</Element>