---
import Button from "./Button.astro"
---

<header class="flex justify-between items-center px-4 py-4 w-full">
  <div class="flex gap-2.5 justify-center items-center shrink-0">
    <img src="/favicon.svg" alt="logo"/> 
    <span class="font-bold text-xl sm:text-2xl md:text-[28px]">HatchHouseLLP</span>
  </div>

  <div class="flex md:hidden">
    <Button text="Contact Now" variant="primary" href="#contact" class="text-[14px]!" target="_self"/>
  </div>

  <div class="hidden md:flex items-center gap-4 lg:gap-10 xl:gap-[70px]">
    <Button text="Home" variant="ghost" href="#home" target="_self" class="text-sm lg:text-base xl:text-[20px]" />
    <Button text="Our Division" variant="ghost" href="#division" target="_self" class="text-sm lg:text-base xl:text-[20px]"/>
    <Button text="Services" variant="ghost" href="#services" target="_self" class="text-sm lg:text-base xl:text-[20px]" />
    <Button text="Projects" variant="ghost" href="#projects" target="_self" class="text-sm lg:text-base xl:text-[20px]"/>
    <Button text="Contact Now" variant="primary" href="#contact" target="_self" class="text-sm lg:text-base xl:text-[20px] shrink-0" />
  </div>
</header>