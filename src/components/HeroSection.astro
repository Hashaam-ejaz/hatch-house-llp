---
import TextCard from "./TextCard.astro";

const points = [
  "Operational Excellence",
  "Technical Percision",
  "Scalable Solutions",
  "Transparent Execution"
]

---

<section
  class="relative min-h-screen text-white bg-cover bg-center bg-no-repeat py-12 flex flex-col justify-between left-1/2 right-1/2 mx-[-50vw] w-screen px-6 md:px-12 lg:px-24"
  style="background-image: linear-gradient(to right, #000000 0%, rgba(46, 62, 80, 0.15) 100%), url('/hero.jpg');"
>
<div class="relative z-10 w-full pt-4">
  <span
    class="bg-primary/10 text-primary text-sm font-bold px-4 py-2 rounded-full"
  >
    About
  </span>
</div>
<div class="relative z-10 grid grid-cols-1 md:grid-cols-12 gap-8 items-center my-auto w-full pt-8">
    
  <div class="md:col-span-7 space-y-6 max-w-2xl">
    <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-[80px] xl:text-[96px] font-bold tracking-tight leading-tight">
      Hatchhouse LLP
    </h1>
    <p class="text-xl sm:text-2xl md:text-3xl lg:text-[32px] font-semibold text-primary">
      Property & Infrastructure Solutions
    </p>
    <div class="space-y-4 text-[#F5F5F5] text-sm sm:text-base md:text-lg lg:text-xl xl:text-2xl leading-relaxed font-light">
      <p>
        We operate at the intersection of operational excellence and scalable
        technology. HatchHouse LLP provides the sovereign intelligence needed
        to navigate complex real estate landscapes, ensuring every asset
        achieves its full potential.
      </p>
      <p>
        Our approach is rooted in technical precision. From automated
        optimization to predictive infrastructure maintenance, we treat
        property management as an engineering challenge that demands arbitrary
        reliability and transparent execution.
      </p>
    </div>
  </div>

  <div class="hidden lg:block md:col-span-5 lg:justify-self-end w-full max-w-sm">
    <TextCard heading="We Deliver" headingStyles="text-xl font-semibold text-primary mb-6" points={points}/>
  </div>
</div>

<div class="relative z-10 flex flex-col sm:flex-row md:flex-nowrap gap-6 w-full pt-8 max-w-[800px]">
  
  <div class="space-y-2 max-w-[260px] min-w-[200px]">
    <img src="/hero-icon-1.svg" class="w-[30px] h-[30px]" alt="icon" />
    <h4 class="text-sm font-semibold uppercase tracking-wider text-[#E0E3E5]">
      Trusted Expertise
    </h4>
    <p class="text-sm text-[#C6C6CD] font-medium leading-relaxed">
      Years of experience in real estate & infrastructure.
    </p>
  </div>

  <div class="space-y-2 max-w-[260px] min-w-[200px]">
    <img src="/hero-icon-2.svg" class="w-[30px] h-[30px]" alt="icon" />
    <h4 class="text-sm font-semibold uppercase tracking-wider text-[#E0E3E5]">
      End-to-End Solutions
    </h4>
    <p class="text-sm text-[#C6C6CD] font-medium leading-relaxed">
      From acquisition to management & exit.
    </p>
  </div>

  <div class="space-y-2 max-w-[260px] min-w-[200px]">
    <img src="/hero-icon-3.svg" class="w-[30px] h-[30px]" alt="icon" />
    <h4 class="text-sm font-semibold uppercase tracking-wider text-[#E0E3E5]">
      Client Focused
    </h4>
    <p class="text-sm text-[#C6C6CD] font-medium leading-relaxed">
      Long term value through partnership & trust.
    </p>
  </div>
</div>
</section>
