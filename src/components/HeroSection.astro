---
import Button from "./Button.astro";
---

<section
  class="relative min-h-screen text-white bg-cover bg-center bg-no-repeat py-12 flex flex-col justify-between left-1/2 right-1/2 mx-[-50vw] w-screen px-6 md:px-12 lg:px-24"
  style="background-image: linear-gradient(to right, #000000 0%, rgba(46, 62, 80, 0.15) 100%), url('/hero.jpg');"
>
  <div class="relative z-10 w-full pt-4">
    <span
      class="bg-primary/10 text-primary text-sm font-bold px-4 py-2 rounded-full"
    >
      About
    </span>
  </div>

  <div
    class="relative z-10 grid grid-cols-1 lg:grid-cols-12 gap-8 items-center my-auto w-full pt-8"
  >
    <div class="lg:col-span-7 space-y-6 max-w-2xl">
      <h1 class="text-4xl md:text-5xl lg:text-[96px] font-bold tracking-tight">
        Hatchhouse LLP
      </h1>
      <p class="text-xl md:text-[32px] font-semibold text-primary">
        Property & Infrastructure Solutions
      </p>
      <div
        class="space-y-4 text-[#F5F5F5] text-sm md:text-2xl leading-relaxed font-light"
      >
        <p>
          We operate at the intersection of operational excellence and scalable
          technology. HatchHouse LLP provides the sovereign intelligence needed
          to navigate complex real estate landscapes, ensuring every asset
          achieves its full potential.
        </p>
        <p>
          Our approach is rooted in technical precision. From automated
          optimization to predictive infrastructure maintenance, we treat
          property management as an engineering challenge that demands arbitrary
          reliability and transparent execution.
        </p>
      </div>
    </div>

    <div class="hidden xl:block xl:col-span-5 lg:justify-self-end w-full max-w-sm">
      <div class="border border-primary bg-secondary/60 backdrop-blur-[20px] rounded-2xl p-6 md:p-8 shadow-2xl">
        <h3 class="text-xl font-semibold text-primary mb-6">We Deliver</h3>
        <ul class="space-y-4 text-sm font-medium tracking-wide text-gray-200">
          <li class="flex items-center gap-3">
            <img src="/hero-tick.svg" class="w-4 h-4 text-primary shrink-0" />
            Operational Excellence
          </li>
          <li class="flex items-center gap-3">
            <img src="/hero-tick.svg" class="w-4 h-4 text-primary shrink-0" />
            Technical Precision
          </li>
          <li class="flex items-center gap-3">
            <img src="/hero-tick.svg" class="w-4 h-4 text-primary shrink-0" />
            Scalable Solutions
          </li>
          <li class="flex items-center gap-3">
            <img src="/hero-tick.svg" class="w-4 h-4 text-primary shrink-0" />
            Transparent Execution
          </li>
        </ul>
      </div>
    </div>
  </div>

  <div class="relative z-10 grid grid-cols-1 sm:grid-cols-3 gap-6 w-full pt-8" >
    <div class="space-y-2">
      <img src="/hero-icon-1.svg" class="w-[30px] h-[30px]" />
      <h4 class="text-xs font-bold uppercase tracking-wider text-[#F5F5F5]">
        Trusted Expertise
      </h4>
      <p class="text-xs text-gray-400 leading-relaxed max-w-xs">
        Years of experience in real estate & infrastructure.
      </p>
    </div>

    <div class="space-y-2">
      <div class="text-primary">
        <svg
          class="w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
          ></path>
        </svg>
      </div>
      <h4 class="text-xs font-bold uppercase tracking-wider text-[#F5F5F5]">
        End-to-End Solutions
      </h4>
      <p class="text-xs text-gray-400 leading-relaxed max-w-xs">
        From acquisition to management & exit.
      </p>
    </div>

    <div class="space-y-2">
      <div class="text-primary">
        <svg
          class="w-5 h-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
          ></path>
        </svg>
      </div>
      <h4 class="text-xs font-bold uppercase tracking-wider text-[#F5F5F5]">
        Client Focused
      </h4>
      <p class="text-xs text-gray-400 leading-relaxed max-w-xs">
        Long term value through partnership & trust.
      </p>
    </div>
  </div>
</section>
